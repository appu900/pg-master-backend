generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  NOTICE_PERIOD
  EXITED
  EVICTED
  PENDING
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  MAINTENANCE_STAFF
}

enum RoomSharingType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
}

model User {
  id               Int      @id @default(autoincrement())
  role             UserRole
  phoneNumber      String
  email            String   @unique
  fullName         String
  pinCode          String?
  isActive         Boolean  @default(true)
  isBlockedByAdmin Boolean  @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyOwnerProfile PropertyOwnerProfile?
  tenentProfile        TenentProfile?

  property Property[]
  tenancy  Tenancy?

  @@index([phoneNumber])
  @@index([role])
}

model PropertyOwnerProfile {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
  Gender       String?
  Profession   String?
  pinCode      String
  State        String?
  BusinessName String?
  BusinessType String?
  profileImage String?

  BankAcconts BankAccountDetails[]
}

model TenentProfile {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique
  user                    User      @relation(fields: [userId], references: [id])
  geneder                 String?
  profession              String?
  pinCode                 String
  state                   String?
  profileImage            String?
  Address                 String?
  agreementPeriodinMonths Int?      @default(0)
  RentalType              String?
  lockInPeriodsInMonths   Int?      @default(0)
  noticePeriodInDays      Int?      @default(0)
  moveOutDate             DateTime?
  JoiningDate             DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenencies Tenancy @relation(fields: [tenancyId], references: [id])
  tenancyId Int

  @@index([userId])
}

model BankAccountDetails {
  id                     Int                  @id @default(autoincrement())
  propertyOwnerProfileId Int
  profile                PropertyOwnerProfile @relation(fields: [propertyOwnerProfileId], references: [id])
}

model Property {
  id      Int    @id @default(autoincrement())
  name    String
  pinCode String
  ownerId Int
  owner   User   @relation(fields: [ownerId], references: [id])

  rooms   Room[]
  tenents Tenancy[]

  @@index([ownerId])
}

model Room {
  id               Int             @id @default(autoincrement())
  propertyId       Int
  property         Property        @relation(fields: [propertyId], references: [id])
  roomNumber       String          @db.Text
  floorNumber      Int
  totalBeds        Int
  occupiedBeds     Int             @default(0)
  rentPerBed       Decimal         @db.Decimal(10, 2)
  sharingType      RoomSharingType
  meterReadingDate DateTime?
  lastMeterReading Float

  amenity String[]
  images  RoomImages[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants Tenancy[]
}

model RoomImages {
  id     Int    @id @default(autoincrement())
  roomId Int
  room   Room   @relation(fields: [roomId], references: [id])
  url    String
}

// ** tenent section 
model Tenancy {
  id       Int @id @default(autoincrement())
  roomId   Int
  tenentId Int @unique

  propertyId Int

  property Property @relation(fields: [propertyId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])
  tenent   User     @relation(fields: [tenentId], references: [id])

  rentAmount            Decimal  @db.Decimal(10, 2)
  securityDeposit       Decimal  @db.Decimal(10, 2)
  advanceAmount         Decimal? @db.Decimal(10, 2)
  lockInPeriodsInMonths Int?     @default(0)
  noticePeriodInDays    Int?     @default(0)

  initialElectricityReading Decimal? @db.Decimal(10, 2)

  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status         TenantStatus    @default(ACTIVE)
  deletedAt      DateTime?
  tenentProfiles TenentProfile[]

  @@unique([roomId, tenentId])
  @@index([roomId, tenentId])
}
