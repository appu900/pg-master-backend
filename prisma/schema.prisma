generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                      @id @default(autoincrement())
  role                    UserRole
  phoneNumber             String
  email                   String?                  @unique
  fullName                String
  pinCode                 String?
  isActive                Boolean                  @default(true)
  isBlockedByAdmin        Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  adminProfile            AdminProfile?
  complaints              Complaint[]              @relation("ComplaintRaisedBy")
  employeeBooks           EmployeeBook[]
  maintenanceStaffProfile MaintenanceStaffProfile?
  property                Property[]
  propertyOwnerProfile    PropertyOwnerProfile?
  tenancy                 Tenancy?
  tenentProfile           TenentProfile?
  expenses                Expenses[]
  recordedPayments        DuePayment[]             @relation("PaymentRecordedBy")

  @@index([phoneNumber])
  @@index([role])
}

model AdminProfile {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  profileImage String?
  createdBy    String?
  password     String?
  user         User    @relation(fields: [userId], references: [id])
}

model PropertyOwnerProfile {
  id                    Int                  @id @default(autoincrement())
  userId                Int                  @unique
  Gender                String?
  Profession            String?
  pinCode               String
  State                 String?
  BusinessName          String?
  BusinessType          String?
  profileImage          String?
  BusinessProfileStatus Boolean              @default(false)
  BankAcconts           BankAccountDetails[]
  businessDetails       BusinessDetails?
  user                  User                 @relation(fields: [userId], references: [id])

  @@index([pinCode])
  @@index([userId])
}

model PropertyMeterReading {
  id              Int                @id @default(autoincrement())
  propertyId      Int
  month           Int
  year            Int
  previousReading Decimal            @db.Decimal(10, 2)
  currentReading  Decimal            @db.Decimal(10, 2)
  unitConsumed    Decimal            @db.Decimal(10, 2)
  unitPrice       Decimal            @db.Decimal(10, 4)
  status          MeterReadingStatus @default(PENDING)
  submittedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
  @@index([propertyId])
  @@index([propertyId, month, year])
  @@index([status])
}

model RoomMeterReading {
  id              Int       @id @default(autoincrement())
  roomId          Int
  propertyId      Int
  month           Int
  year            Int
  previousReading Decimal   @db.Decimal(10, 2)
  currentReading  Decimal   @db.Decimal(10, 2)
  unitConsumed    Decimal   @db.Decimal(10, 2)
  isSkipped       Boolean   @default(false)
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  room     Room     @relation(fields: [roomId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([roomId, month, year])
  @@index([roomId])
  @@index([propertyId, month, year])
  @@index([isSkipped])
}

model ElectricityBillingRun {
  id                Int              @id @default(autoincrement())
  propertyId        Int
  month             Int
  year              Int
  status            BillingRunStatus @default(PENDING)
  mainMeterUnits    Decimal          @db.Decimal(10, 2)
  privateRoomsUnits Decimal          @db.Decimal(10, 2)
  sharedPoolUnits   Decimal          @db.Decimal(10, 2)
  unitPrice         Decimal          @db.Decimal(10, 4)
  totalDaysPool     Int?
  perDayRate        Decimal?         @db.Decimal(10, 6)

  roomReminderSentAt   DateTime?
  mainMeterReminder1At DateTime?
  mainMeterReminder2At DateTime?

  ranAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
  @@index([propertyId])
  @@index([status])
  @@index([propertyId, month, year])
}

model TenentProfile {
  id                      Int               @id @default(autoincrement())
  userId                  Int               @unique
  geneder                 String?
  profession              String?
  pinCode                 String
  state                   String?
  profileImage            String?
  Address                 String?
  RentalType              String?
  lockInPeriodsInMonths   Int?              @default(0)
  noticePeriodInDays      Int?              @default(0)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  JoiningDate             DateTime
  agreementPeriodinMonths Int?              @default(0)
  moveOutDate             DateTime?
  user                    User              @relation(fields: [userId], references: [id])
  tenantKycDetails        TenantKycDetails?

  @@index([userId])
}

model TenantKycDetails {
  id                                Int           @id @default(autoincrement())
  tenantProfileId                   Int           @unique
  idProof                           String?
  rentalAgreement                   String?
  policeVerification                String?
  otherDocument                     String?
  RentingDetailsVerificationStatus  Boolean       @default(false)
  IdVerificationStatus              Boolean       @default(false)
  RentalAgreementVerificationStatus Boolean       @default(false)
  TenantProfile                     TenentProfile @relation(fields: [tenantProfileId], references: [id])
}

model BankAccountDetails {
  id                     Int                  @id @default(autoincrement())
  propertyOwnerProfileId Int
  AccountNumber          String?
  IFSCcode               String?
  PayeeCategory          payeeCategory
  UPIId                  String?
  accountHolderName      String
  createdAt              DateTime             @default(now())
  phoneNumber            String
  updatedAt              DateTime             @updatedAt
  accountType            AccountDetailsType?
  profile                PropertyOwnerProfile @relation(fields: [propertyOwnerProfileId], references: [id])
  linkedProperty         Property[]

  @@index([propertyOwnerProfileId])
}

model BusinessDetails {
  id                     Int                    @id @default(autoincrement())
  businessName           String
  businessType           BusinessType
  propertyOwnerProfileId Int                    @unique
  panCard                String
  companyDocument        String?
  rejectionReason        String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  aadhaarCard            String
  status                 BusinessApprovalStatus
  propertyOwnerProfile   PropertyOwnerProfile   @relation(fields: [propertyOwnerProfileId], references: [id])

  @@index([status])
  @@index([propertyOwnerProfileId])
}

model Property {
  id            Int    @id @default(autoincrement())
  name          String
  pinCode       String
  ownerId       Int
  bankAccountId Int?

  complaints                     Complaint[]
  invoices                       Invoice[]
  maintenanceStaffPropertyAccess MaintenanceStaffPropertyAccess[]
  bankAccount                    BankAccountDetails?              @relation(fields: [bankAccountId], references: [id])
  owner                          User                             @relation(fields: [ownerId], references: [id])
  rooms                          Room[]
  tenents                        Tenancy[]

  expenses                 Expenses[]
  dues                     TenantDue[]
  dailyReminderQueues      DailyReminderQueue[]
  propertyMetrics          PropertyMetrics[]
  propertyMeterReadings    PropertyMeterReading[]
  roomMeterReadings        RoomMeterReading[]
  electricityBillingRuns   ElectricityBillingRun[]
  paymentGatewayConfig     PropertyPaymentGatewayConfig?
  gatewayTransactions      PaymentGatewayTransaction[]

  @@index([ownerId])
  @@index([pinCode])
}

model Room {
  id                 Int                @id @default(autoincrement())
  propertyId         Int
  floorNumber        Int
  totalBeds          Int
  occupiedBeds       Int                @default(0)
  rentPerBed         Decimal            @db.Decimal(10, 2)
  sharingType        RoomSharingType
  meterReadingDate   DateTime?
  amenity            String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  hasMeter           Boolean            @default(false)
  intialMeterReading Int?
  isAcRoom           Boolean            @default(false)
  lastMeterReading   Float?
  roomNumber         String
  property           Property           @relation(fields: [propertyId], references: [id])
  images             RoomImages[]
  tenants            Tenancy[]
  roomMeterReadings  RoomMeterReading[]

  @@index([propertyId])
  @@index([sharingType])
  @@index([propertyId, floorNumber])
}

model RoomImages {
  id     Int    @id @default(autoincrement())
  roomId Int
  url    String
  room   Room   @relation(fields: [roomId], references: [id])

  @@index([roomId])
}

model Tenancy {
  id            Int           @id @default(autoincrement())
  roomId        Int
  tenentId      Int           @unique
  propertyId    Int
  tenancyStatus TenancyStatus @default(ACTIVE)

  rentAmount      Decimal  @db.Decimal(10, 2)
  securityDeposit Decimal  @db.Decimal(10, 2)
  advanceAmount   Decimal? @db.Decimal(10, 2)

  billingCycleDay Int
  joinedAt        DateTime @db.Date

  lockInPeriodsInMonths     Int?      @default(0)
  noticePeriodInDays        Int?      @default(0)
  initialElectricityReading Decimal?  @db.Decimal(10, 2)
  leftAt                    DateTime?
  deletedAt                 DateTime?

  nextBillingDate DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  dues     TenantDue[]

  property            Property             @relation(fields: [propertyId], references: [id])
  room                Room                 @relation(fields: [roomId], references: [id])
  tenent              User                 @relation(fields: [tenentId], references: [id])
  dailyReminderQueues DailyReminderQueue[]

  @@unique([roomId, tenentId])
  @@index([roomId, tenentId])
  @@index([propertyId])
  @@index([tenancyStatus])
  @@index([joinedAt])
  @@index([nextBillingDate])
}

model TenantDue {
  id          Int     @id @default(autoincrement())
  tenancyId   Int
  propertyId  Int
  dueType     DueType
  title       String
  description String?

  month Int
  year  Int

  totalAmount   Decimal @db.Decimal(10, 2)
  paidAmount    Decimal @default(0) @db.Decimal(10, 2)
  balanceAmount Decimal @db.Decimal(10, 2)

  status DueStatus @default(UNPAID)

  periodStart DateTime? @db.Date
  periodEnd   DateTime? @db.Date
  dueDate     DateTime  @db.Date

  invoiceId Int?     @unique
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenancy             Tenancy                    @relation(fields: [tenancyId], references: [id])
  property            Property                   @relation(fields: [propertyId], references: [id])
  payments            DuePayment[]
  dailyReminderQueue  DailyReminderQueue?
  gatewayTransactions PaymentGatewayTransaction[]

  @@index([tenancyId])
  @@index([propertyId])
  @@index([status])
  @@index([dueType])
  @@index([dueDate])
  @@index([tenancyId, status])
  @@index([tenancyId, dueType])
}

model DuePayment {
  id         Int @id @default(autoincrement())
  dueId      Int
  tenancyId  Int
  propertyId Int

  month Int
  year  Int

  amount      Decimal     @db.Decimal(10, 2)
  paymentMode PaymentMode
  upiApp      UpiApp?

  transactionId String?
  proofImageUrl String?

  recordedById Int
  recordedBy   User @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  notes  String?
  paidAt DateTime

  invoiceId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  due TenantDue @relation(fields: [dueId], references: [id])

  @@index([dueId])
  @@index([tenancyId])
  @@index([propertyId])
  @@index([recordedById])
  @@index([paidAt])
  @@index([tenancyId, paidAt])
}

model Invoice {
  id Int @id @default(autoincrement())

  property   Property?  @relation(fields: [propertyId], references: [id])
  propertyId Int?
  tenancy    Tenancy?   @relation(fields: [tenancyId], references: [id])
  tenancyId  Int?
  tenantDue  TenantDue?
}

model MaintenanceStaffProfile {
  id                               Int                              @id @default(autoincrement())
  userId                           Int                              @unique
  phoneNumber                      String
  whatsAppNumber                   String?
  staffType                        MaintenanceStaffType
  jobPosition                      MaintenanceJobPosition
  monthlySalary                    Decimal                          @db.Decimal(10, 2)
  propertyScope                    PropertyAccessScope
  isActive                         Boolean                          @default(true)
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  complaints                       Complaint[]
  employeeBooks                    EmployeeBook?
  user                             User                             @relation(fields: [userId], references: [id])
  maintenanceStaffPropertyAccesses MaintenanceStaffPropertyAccess[]

  @@index([userId])
  @@index([staffType])
  @@index([isActive])
}

model MaintenanceStaffPropertyAccess {
  id             Int                     @id @default(autoincrement())
  propertyId     Int
  staffProfileId Int
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  property       Property                @relation(fields: [propertyId], references: [id])
  staffProfile   MaintenanceStaffProfile @relation(fields: [staffProfileId], references: [id])

  @@index([propertyId])
  @@index([staffProfileId])
  @@index([propertyId, staffProfileId])
}

model EmployeeBook {
  id                Int                     @id @default(autoincrement())
  ownerId           Int
  employeeProfileId Int                     @unique
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  employeeProfile   MaintenanceStaffProfile @relation(fields: [employeeProfileId], references: [id])
  owner             User                    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([employeeProfileId])
  @@index([ownerId, employeeProfileId])
}

model Complaint {
  id                                Int                      @id @default(autoincrement())
  title                             String
  description                       String
  raisedById                        Int
  assignedMaintenanceStaffProfileId Int?
  status                            ComplaintStatus          @default(OPEN)
  createdAt                         DateTime                 @default(now())
  updatedAt                         DateTime                 @updatedAt
  propertyId                        Int
  requestedVisitDate                DateTime?                @db.Date
  requestedVisitTime                DateTime?                @db.Time(6)
  priority                          MaintenancePriority?
  roomNumber                        String?
  assignedMaintenanceStaffProfile   MaintenanceStaffProfile? @relation(fields: [assignedMaintenanceStaffProfileId], references: [id])
  property                          Property                 @relation(fields: [propertyId], references: [id])
  raisedBy                          User                     @relation("ComplaintRaisedBy", fields: [raisedById], references: [id])
  logs                              ComplaintActivityLog[]
  images                            ComplaintPhoto[]

  @@index([raisedById])
  @@index([assignedMaintenanceStaffProfileId])
  @@index([status])
}

model ComplaintActivityLog {
  id          Int       @id @default(autoincrement())
  title       String
  complaintId Int
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model ComplaintPhoto {
  id          Int       @id @default(autoincrement())
  complaintId Int
  imageUrl    String
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model DailyReminderQueue {
  id                     Int                     @id @default(autoincrement())
  dueId                  Int                     @unique
  tenancyId              Int
  propertyId             Int
  tenantPhone            String
  dueType                DueType
  TenantName             String
  dueAmount              Decimal                 @db.Decimal(10, 2)
  dueDate                DateTime                @db.Date
  title                  String
  lastSentAt             DateTime?
  sentCount              Int                     @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  lastReminderSendStatus ReminderScheduleStatus?

  due      TenantDue @relation(fields: [dueId], references: [id])
  tenancy  Tenancy   @relation(fields: [tenancyId], references: [id])
  property Property  @relation(fields: [propertyId], references: [id])

  @@index([tenancyId])
  @@index([propertyId])
  @@index([dueDate])
}

model OutBox {
  id          Int          @id @default(autoincrement())
  messageType String
  payload     Json
  status      OutboxStatus @default(PENDING)
  retryCount  Int          @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([messageType])
  @@index([messageType, status])
}

model InboxMessages {
  id             Int                @id @default(autoincrement())
  queueMessageId String             @unique
  messageType    String
  payload        Json
  status         InboxMessageStatus @default(PENDING)
  processedAt    DateTime?
  failedReason   String?
  retryCount     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
  @@index([queueMessageId])
  @@index([messageType, status])
}

model Expenses {
  id              Int             @id @default(autoincrement())
  propertyId      Int
  month           Int
  year            Int
  amount          Decimal         @default(0) @db.Decimal(10, 2)
  description     String
  expenseCategory ExpenseCategory
  modeOfPayment   ModeOfPayment
  payerUserId     Int
  RecipientName   String
  transactionId   String?
  paymentDate     DateTime
  image           String?

  property Property @relation(fields: [propertyId], references: [id])
  payer    User     @relation(fields: [payerUserId], references: [id])

  @@index([payerUserId])
  @@index([propertyId])
  @@index([propertyId, modeOfPayment])
}

model PropertyMetrics {
  id         Int @id @default(autoincrement())
  propertyId Int
  ownerId    Int
  month      Int
  year       Int

  totalRentCollected  Decimal @default(0) @db.Decimal(10, 2)
  totalElecCollected  Decimal @default(0) @db.Decimal(10, 2)
  totalOtherCollected Decimal @default(0) @db.Decimal(10, 2)
  totalExpenses       Decimal @default(0) @db.Decimal(10, 2)

  totalBeds     Int @default(0)
  occupiedBeds  Int @default(0)
  activeTenants Int @default(0)

  totalDuesGenerated Decimal @default(0) @db.Decimal(10, 2)
  totalDuesPaid      Decimal @default(0) @db.Decimal(10, 2)
  totalDuesUnpaid    Decimal @default(0) @db.Decimal(10, 2)
  overdueCount       Int     @default(0)

  collectionRate Decimal @default(0) @db.Decimal(5, 2)
  netProfit      Decimal @default(0) @db.Decimal(10, 2)
  occupancyRate  Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
  @@index([ownerId, month, year])
  @@index([propertyId])
}

model PropertyPaymentGatewayConfig {
  id           Int                @id @default(autoincrement())
  propertyId   Int                @unique
  merchantKey  String
  merchantSalt String
  environment  GatewayEnvironment @default(TEST)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model PaymentGatewayTransaction {
  id            Int                      @id @default(autoincrement())
  dueId         Int
  tenancyId     Int
  propertyId    Int
  txnId         String                   @unique
  amount        Decimal                  @db.Decimal(10, 2)
  status        GatewayTransactionStatus @default(INITIATED)
  accessKey     String?
  easepayId     String?
  paymentSource String?
  rawResponse   Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  due      TenantDue @relation(fields: [dueId], references: [id])
  property Property  @relation(fields: [propertyId], references: [id])

  @@index([dueId])
  @@index([tenancyId])
  @@index([propertyId])
  @@index([status])
}

enum GatewayEnvironment {
  TEST
  PRODUCTION
}

enum GatewayTransactionStatus {
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
}

enum DueType {
  RENT
  SECURITY_DEPOSIT
  ELECTRICITY
  WATER
  MAINTENANCE
  FINE
  OTHER
}

enum DueStatus {
  UNPAID
  PARTIAL
  PAID
  WAIVED
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE_GATEWAY
}

enum UpiApp {
  GOOGLE_PAY
  PHONE_PE
  PAYTM
  BHIM
  AMAZON_PAY
  OTHER
}

enum InboxMessageStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MeterReadingStatus {
  PENDING
  SUBMITTED
  SKIPPED
}

enum BillingRunStatus {
  PENDING
  WAITING_MAIN_METER
  COMPLETED
  SKIPPED
}

enum ExpenseCategory {
  ELECTRICITY_BILL
  WATERBILL
  EMPLOYEE_SALARY
  CLEANING_STAFF_SALARY
  SECURITY_GUARD_SALARY
  MAINTENANCE_REPAIR
  PLUMBING
  ELECTRICAL_REPAIR
  INTERNET_WIFI
  DRINKING_WATER_CANS
  LAUNDRY
  CLEANING_SUPPLIES
  FURNITURE
  APPLIANCES
  PROPERTY_RENT
  SOCIETY_MAINTENANCE
  PEST_CONTROL
  BROKER_COMMISSION
  TRANSPORT
  MISCELLANEOUS
  OTHER
}

enum ModeOfPayment {
  ONLINE
  CASH
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TenantStatus {
  ACTIVE
  NOTICE_PERIOD
  EXITED
  EVICTED
  PENDING
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  MAINTENANCE_STAFF
}

enum RoomSharingType {
  SINGLE_SHARING
  DOUBLE_SHARING
  TRIPLE_SHARING
  QUAD_SHARING
  FIVE_SHARING
  SIX_SHARING
  SEVEN_SHARING
  EIGHT_SHARING
  NINE_SHARING
  TEN_SHARING
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintStatus {
  OPEN
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStaffType {
  ADMIN_STAFF
  SERVICE_STAFF
}

enum MaintenanceJobPosition {
  ELECTRICIAN
  PLUMBER
  CLEANER
  CARPENTER
  SECURITY
  MANAGER
  OTHER
  OWNER
  CO_PARTNER
  SUPERVISOR
  ACCOUNTANT
  OPERATIONS_HEAD
}

enum BusinessType {
  INDIVIDUAL
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LIMITED
  LLP
  OTHER
}

enum BusinessDetailsStatus {
  APPROVED
  REJECTED
  PENDING
}

enum BusinessApprovalStatus {
  APPROVED
  REJECTED
  PENDING
}

enum PropertyAccessScope {
  ALL_PROPERTIES
  SELECTIVE
}

enum payeeCategory {
  OWNER
  MANAGER
  STAFF
  EMPLOYEE
  OTHER
}

enum AccountDetailsType {
  BANKACCOUNT
  UPI
  BOTH
}

enum InvoiceType {
  MONTHLY_RENT
  PRORATED_FIRST
  PRORATED_LAST
  SECURITY_DEPOSIT
  ADDITIONAL_CHARGES
  FINAL_SETTLEMENT
}

enum InvoiceStatus {
  DRAFT
  PENDING
  DUE
  OVERDUE
  PARTIALLY_PAID
  PAID
  CANCELLED
  WAIVED
}

enum ChargeType {
  RENT
  ELECTRICITY
  WATER
  MAINTENANCE
  FINE
  LATE_FEE
  SECURITY_DEPOSIT
  ADVANCE
  OTHER
}

enum ChargeStatus {
  PENDING
  ATTACHED
  CANCELLED
}

enum PaymentMethod {
  UPI
  BANK_TRANSFER
  CASH
  CHEQUE
  ONLINE_GATEWAY
  WALLET
  AUTO_DEBIT
}

enum PaymentStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REFUND_INITIATED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum ReminderType {
  PAYMENT_WINDOW_OPEN
  PAYMENT_DUE_SOON
  PAYMENT_DUE_TODAY
  PAYMENT_OVERDUE
  PAYMENT_RECEIVED
  INVOICE_GENERATED
  CHARGE_ADDED
  MOVE_OUT_REMINDER
  WELCOME
  DUE_CREATED
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  EXPIRED
}

enum ReminderScheduleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum LateFeeType {
  FIXED
  PERCENTAGE
  PER_DAY_FIXED
  PER_DAY_PERCENTAGE
}

enum SQSMessageType {
  GENERATE_INVOICE
  SEND_REMINDER
  PROCESS_PAYMENT
  APPLY_LATE_FEE
  ATTACH_CHARGES
  SCHEDULE_REMINDERS
  SEND_WHATSAPP
  PAYMENT_CONFIRMATION
  INVOICE_NOTIFICATION
  CHARGE_NOTIFICATION
  CRON_DAILY_BILLING
  CRON_REMINDER_SCAN
  CREATE_DUE_PAYMENT
  GENERATE_INVOICE_FOR_DUE
}

enum SQSProcessStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

