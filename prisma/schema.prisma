generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  MAINTENANCE_STAFF
}

enum RoomSharingType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
}

model User {
  id               Int      @id @default(autoincrement())
  role             UserRole
  phoneNumber      String
  email            String   @unique
  fullName         String
  pinCode          String?
  isActive         Boolean  @default(true)
  isBlockedByAdmin Boolean  @default(false)

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  propertyOwnerProfile PropertyOwnerProfile?

  property Property[]

  @@index([phoneNumber])
  @@index([role])
}

model PropertyOwnerProfile {
  id           Int                  @id @default(autoincrement())
  userId       Int                  @unique
  user         User                 @relation(fields: [userId], references: [id])
  Gender       String?
  Profession   String?
  pinCode      String
  State        String?
  BusinessName String?
  BusinessType String?
  profileImage String?
  BankAcconts  BankAccountDetails[]
}

model BankAccountDetails {
  id                     Int                  @id @default(autoincrement())
  propertyOwnerProfileId Int
  profile                PropertyOwnerProfile @relation(fields: [propertyOwnerProfileId], references: [id])
}

model Property {
  id      Int    @id @default(autoincrement())
  name    String
  pinCode String
  ownerId Int
  owner   User   @relation(fields: [ownerId], references: [id])

  rooms Room[]

  @@index([ownerId])
}

model Room {
  id               Int             @id @default(autoincrement())
  propertyId       Int
  property         Property        @relation(fields: [propertyId], references: [id])
  roomName         String
  floorNumber      Int
  totalBeds        Int
  occupiedBeds     Int             @default(0)
  rentPerBed       Int
  sharingType      RoomSharingType
  meterReadingDate DateTime?

  amenity String[]
  images  RoomImages[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomImages {
  id     Int    @id @default(autoincrement())
  roomId Int
  room   Room   @relation(fields: [roomId], references: [id])
  url    String
}
