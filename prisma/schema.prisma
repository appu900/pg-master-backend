generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                      @id @default(autoincrement())
  role                    UserRole
  phoneNumber             String
  email                   String?                  @unique
  fullName                String
  pinCode                 String?
  isActive                Boolean                  @default(true)
  isBlockedByAdmin        Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  complaints              Complaint[]              @relation("ComplaintRaisedBy")
  employeeBooks           EmployeeBook[]
  maintenanceStaffProfile MaintenanceStaffProfile?
  adminProfile            AdminProfile?
  property                Property[]
  propertyOwnerProfile    PropertyOwnerProfile?
  tenancy                 Tenancy?
  tenentProfile           TenentProfile?

  @@index([phoneNumber])
  @@index([role])
}

model AdminProfile {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  user         User    @relation(fields: [userId], references: [id])
  profileImage String?
  createdBy    String?
}

model PropertyOwnerProfile {
  id                    Int                  @id @default(autoincrement())
  userId                Int                  @unique
  Gender                String?
  Profession            String?
  pinCode               String
  State                 String?
  BusinessName          String?
  BusinessType          String?
  profileImage          String?
  BusinessProfileStatus Boolean              @default(false)
  BankAcconts           BankAccountDetails[]
  user                  User                 @relation(fields: [userId], references: [id])
  businessDetails       BusinessDetails[]

  @@index([pinCode])
  @@index([userId])
}

model TenentProfile {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique
  geneder                 String?
  profession              String?
  pinCode                 String
  state                   String?
  profileImage            String?
  Address                 String?
  RentalType              String?
  lockInPeriodsInMonths   Int?      @default(0)
  noticePeriodInDays      Int?      @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  JoiningDate             DateTime
  agreementPeriodinMonths Int?      @default(0)
  moveOutDate             DateTime?
  user                    User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BankAccountDetails {
  id                     Int                  @id @default(autoincrement())
  propertyOwnerProfileId Int
  profile                PropertyOwnerProfile @relation(fields: [propertyOwnerProfileId], references: [id])
}

model BusinessDetails {
  id                     Int                    @id @default(autoincrement())
  businessName           String
  businessType           BusinessType
  status                 BusinessApprovalStatus
  propertyOwnerProfileId Int                    @unique

  aadhaarCard     String
  panCard         String
  companyDocument String?
  rejectionReason String? @db.Text

  propertyOwnerProfile PropertyOwnerProfile @relation(fields: [propertyOwnerProfileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([propertyOwnerProfileId])
}

model Property {
  id                             Int                              @id @default(autoincrement())
  name                           String
  pinCode                        String
  ownerId                        Int
  complaints                     Complaint[]
  maintenanceStaffPropertyAccess MaintenanceStaffPropertyAccess[]
  owner                          User                             @relation(fields: [ownerId], references: [id])
  rooms                          Room[]
  tenents                        Tenancy[]

  @@index([ownerId])
  @@index([pinCode])
}

model Room {
  id               Int             @id @default(autoincrement())
  propertyId       Int
  floorNumber      Int
  totalBeds        Int
  occupiedBeds     Int             @default(0)
  rentPerBed       Decimal         @db.Decimal(10, 2)
  sharingType      RoomSharingType
  meterReadingDate DateTime?
  amenity          String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  lastMeterReading Float
  roomNumber       String
  property         Property        @relation(fields: [propertyId], references: [id])
  images           RoomImages[]
  tenants          Tenancy[]

  @@index([propertyId])
  @@index([sharingType])
  @@index([propertyId, floorNumber])
}

model RoomImages {
  id     Int    @id @default(autoincrement())
  roomId Int
  url    String
  room   Room   @relation(fields: [roomId], references: [id])

  @@index([roomId])
}

model Tenancy {
  id                        Int          @id @default(autoincrement())
  roomId                    Int
  tenentId                  Int          @unique
  propertyId                Int
  rentAmount                Decimal      @db.Decimal(10, 2)
  securityDeposit           Decimal      @db.Decimal(10, 2)
  advanceAmount             Decimal?     @db.Decimal(10, 2)
  lockInPeriodsInMonths     Int?         @default(0)
  noticePeriodInDays        Int?         @default(0)
  initialElectricityReading Decimal?     @db.Decimal(10, 2)
  joinedAt                  DateTime     @db.Date
  leftAt                    DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  deletedAt                 DateTime?
  status                    TenantStatus @default(ACTIVE)
  property                  Property     @relation(fields: [propertyId], references: [id])
  room                      Room         @relation(fields: [roomId], references: [id])
  tenent                    User         @relation(fields: [tenentId], references: [id])

  @@unique([roomId, tenentId])
  @@index([roomId, tenentId])
  @@index([propertyId])
  @@index([status])
  @@index([joinedAt])
}

model MaintenanceStaffProfile {
  id                               Int                              @id @default(autoincrement())
  userId                           Int                              @unique
  phoneNumber                      String
  whatsAppNumber                   String?
  staffType                        MaintenanceStaffType
  jobPosition                      MaintenanceJobPosition
  monthlySalary                    Decimal                          @db.Decimal(10, 2)
  propertyScope                    PropertyAccessScope
  isActive                         Boolean                          @default(true)
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  complaints                       Complaint[]
  employeeBooks                    EmployeeBook?
  user                             User                             @relation(fields: [userId], references: [id])
  maintenanceStaffPropertyAccesses MaintenanceStaffPropertyAccess[]

  @@index([userId])
  @@index([staffType])
  @@index([isActive])
}

model MaintenanceStaffPropertyAccess {
  id             Int                     @id @default(autoincrement())
  propertyId     Int
  staffProfileId Int
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  property       Property                @relation(fields: [propertyId], references: [id])
  staffProfile   MaintenanceStaffProfile @relation(fields: [staffProfileId], references: [id])

  @@index([propertyId])
  @@index([staffProfileId])
  @@index([propertyId, staffProfileId])
}

model EmployeeBook {
  id                Int                     @id @default(autoincrement())
  ownerId           Int
  employeeProfileId Int                     @unique
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  employeeProfile   MaintenanceStaffProfile @relation(fields: [employeeProfileId], references: [id])
  owner             User                    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([employeeProfileId])
  @@index([ownerId, employeeProfileId])
}

model Complaint {
  id                                Int                      @id @default(autoincrement())
  title                             String
  description                       String
  raisedById                        Int
  assignedMaintenanceStaffProfileId Int?
  status                            ComplaintStatus          @default(OPEN)
  createdAt                         DateTime                 @default(now())
  updatedAt                         DateTime                 @updatedAt
  propertyId                        Int
  requestedVisitDate                DateTime?                @db.Date
  requestedVisitTime                DateTime?                @db.Time(6)
  priority                          MaintenancePriority?
  roomNumber                        String?
  assignedMaintenanceStaffProfile   MaintenanceStaffProfile? @relation(fields: [assignedMaintenanceStaffProfileId], references: [id])
  property                          Property                 @relation(fields: [propertyId], references: [id])
  raisedBy                          User                     @relation("ComplaintRaisedBy", fields: [raisedById], references: [id])
  logs                              ComplaintActivityLog[]
  images                            ComplaintPhoto[]

  @@index([raisedById])
  @@index([assignedMaintenanceStaffProfileId])
  @@index([status])
}

model ComplaintActivityLog {
  id          Int       @id @default(autoincrement())
  title       String
  complaintId Int
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model ComplaintPhoto {
  id          Int       @id @default(autoincrement())
  complaintId Int
  imageUrl    String
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

enum TenantStatus {
  ACTIVE
  NOTICE_PERIOD
  EXITED
  EVICTED
  PENDING
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  MAINTENANCE_STAFF
}

enum RoomSharingType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintStatus {
  OPEN
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStaffType {
  ADMIN_STAFF
  SERVICE_STAFF
}

enum MaintenanceJobPosition {
  ELECTRICIAN
  PLUMBER
  CLEANER
  CARPENTER
  SECURITY
  MANAGER
  OTHER
  OWNER
  CO_PARTNER
  SUPERVISOR
  ACCOUNTANT
  OPERATIONS_HEAD
}

enum BusinessType {
  INDIVIDUAL
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LIMITED
  LLP
  OTHER
}

enum BusinessDetailsStatus {
  APPROVED
  REJECTED
  PENDING
}

enum BusinessApprovalStatus {
  APPROVED
  REJECTED
  PENDING
}

enum PropertyAccessScope {
  ALL_PROPERTIES
  SELECTIVE
}
