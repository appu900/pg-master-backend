generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                      @id @default(autoincrement())
  role                    UserRole
  phoneNumber             String
  email                   String?                  @unique
  fullName                String
  pinCode                 String?
  isActive                Boolean                  @default(true)
  isBlockedByAdmin        Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  adminProfile            AdminProfile?
  complaints              Complaint[]              @relation("ComplaintRaisedBy")
  employeeBooks           EmployeeBook[]
  maintenanceStaffProfile MaintenanceStaffProfile?
  property                Property[]
  propertyOwnerProfile    PropertyOwnerProfile?
  tenancy                 Tenancy?
  tenentProfile           TenentProfile?

  @@index([phoneNumber])
  @@index([role])
}

model AdminProfile {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  profileImage String?
  createdBy    String?
  password     String?
  user         User    @relation(fields: [userId], references: [id])
}

model PropertyOwnerProfile {
  id                    Int                  @id @default(autoincrement())
  userId                Int                  @unique
  Gender                String?
  Profession            String?
  pinCode               String
  State                 String?
  BusinessName          String?
  BusinessType          String?
  profileImage          String?
  BusinessProfileStatus Boolean              @default(false)
  BankAcconts           BankAccountDetails[]
  businessDetails       BusinessDetails?
  user                  User                 @relation(fields: [userId], references: [id])

  @@index([pinCode])
  @@index([userId])
}

model TenentProfile {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique
  geneder                 String?
  profession              String?
  pinCode                 String
  state                   String?
  profileImage            String?
  Address                 String?
  RentalType              String?
  lockInPeriodsInMonths   Int?      @default(0)
  noticePeriodInDays      Int?      @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  JoiningDate             DateTime
  agreementPeriodinMonths Int?      @default(0)
  moveOutDate             DateTime?
  user                    User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model TenantKycDetails{
  id Int @id @default(autoincrement())
}
  
model BankAccountDetails {
  id                     Int                  @id @default(autoincrement())
  propertyOwnerProfileId Int
  AccountNumber          String?
  IFSCcode               String?
  PayeeCategory          payeeCategory
  UPIId                  String?
  accountHolderName      String
  createdAt              DateTime             @default(now())
  phoneNumber            String
  updatedAt              DateTime             @updatedAt
  accountType            AccountDetailsType?
  profile                PropertyOwnerProfile @relation(fields: [propertyOwnerProfileId], references: [id])
  linkedProperty         Property[]

  @@index([propertyOwnerProfileId])
}

model BusinessDetails {
  id                     Int                    @id @default(autoincrement())
  businessName           String
  businessType           BusinessType
  propertyOwnerProfileId Int                    @unique
  panCard                String
  companyDocument        String?
  rejectionReason        String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  aadhaarCard            String
  status                 BusinessApprovalStatus
  propertyOwnerProfile   PropertyOwnerProfile   @relation(fields: [propertyOwnerProfileId], references: [id])

  @@index([status])
  @@index([propertyOwnerProfileId])
}

model Property {
  id            Int    @id @default(autoincrement())
  name          String
  pinCode       String
  ownerId       Int
  bankAccountId Int?

  complaints                     Complaint[]
  invoices                       Invoice[]
  maintenanceStaffPropertyAccess MaintenanceStaffPropertyAccess[]
  bankAccount                    BankAccountDetails?              @relation(fields: [bankAccountId], references: [id])
  owner                          User                             @relation(fields: [ownerId], references: [id])
  rooms                          Room[]
  tenents                        Tenancy[]
  charges                        TenantCharge[]
  propertyMonthlyMetrics         PropertyMonthlyMetrics[]
  propertyLifetimeMetrics        PropertyLifetimeMetrics?

  @@index([ownerId])
  @@index([pinCode])
}

model Room {
  id               Int             @id @default(autoincrement())
  propertyId       Int
  floorNumber      Int
  totalBeds        Int
  occupiedBeds     Int             @default(0)
  rentPerBed       Decimal         @db.Decimal(10, 2)
  sharingType      RoomSharingType
  meterReadingDate DateTime?
  amenity          String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  lastMeterReading Float
  roomNumber       String
  property         Property        @relation(fields: [propertyId], references: [id])
  images           RoomImages[]
  tenants          Tenancy[]

  @@index([propertyId])
  @@index([sharingType])
  @@index([propertyId, floorNumber])
}

model RoomImages {
  id     Int    @id @default(autoincrement())
  roomId Int
  url    String
  room   Room   @relation(fields: [roomId], references: [id])

  @@index([roomId])
}

model Tenancy {
  id                        Int                @id @default(autoincrement())
  roomId                    Int
  tenentId                  Int                @unique
  propertyId                Int
  tenancyStatus             TenancyStatus?
  rentAmount                Decimal            @db.Decimal(10, 2)
  securityDeposit           Decimal            @db.Decimal(10, 2)
  advanceAmount             Decimal?           @db.Decimal(10, 2)
  lockInPeriodsInMonths     Int?               @default(0)
  noticePeriodInDays        Int?               @default(0)
  initialElectricityReading Decimal?           @db.Decimal(10, 2)
  joinedAt                  DateTime           @db.Date
  leftAt                    DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  deletedAt                 DateTime?
  status                    TenantStatus       @default(ACTIVE)
  billingDayOfMonth         Int                @default(1)
  firstInvoiceGenerated     Boolean            @default(false)
  lastInvoicePeriodEnd      DateTime?          @db.Date
  invoices                  Invoice[]
  payments                  Payment[]
  reminderSchedules         ReminderSchedule[]
  property                  Property           @relation(fields: [propertyId], references: [id])
  room                      Room               @relation(fields: [roomId], references: [id])
  tenent                    User               @relation(fields: [tenentId], references: [id])
  charges                   TenantCharge[]

  @@unique([roomId, tenentId])
  @@index([roomId, tenentId])
  @@index([propertyId])
  @@index([status])
  @@index([joinedAt])
}

model MaintenanceStaffProfile {
  id                               Int                              @id @default(autoincrement())
  userId                           Int                              @unique
  phoneNumber                      String
  whatsAppNumber                   String?
  staffType                        MaintenanceStaffType
  jobPosition                      MaintenanceJobPosition
  monthlySalary                    Decimal                          @db.Decimal(10, 2)
  propertyScope                    PropertyAccessScope
  isActive                         Boolean                          @default(true)
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  complaints                       Complaint[]
  employeeBooks                    EmployeeBook?
  user                             User                             @relation(fields: [userId], references: [id])
  maintenanceStaffPropertyAccesses MaintenanceStaffPropertyAccess[]

  @@index([userId])
  @@index([staffType])
  @@index([isActive])
}

model MaintenanceStaffPropertyAccess {
  id             Int                     @id @default(autoincrement())
  propertyId     Int
  staffProfileId Int
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  property       Property                @relation(fields: [propertyId], references: [id])
  staffProfile   MaintenanceStaffProfile @relation(fields: [staffProfileId], references: [id])

  @@index([propertyId])
  @@index([staffProfileId])
  @@index([propertyId, staffProfileId])
}

model EmployeeBook {
  id                Int                     @id @default(autoincrement())
  ownerId           Int
  employeeProfileId Int                     @unique
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  employeeProfile   MaintenanceStaffProfile @relation(fields: [employeeProfileId], references: [id])
  owner             User                    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([employeeProfileId])
  @@index([ownerId, employeeProfileId])
}

model Complaint {
  id                                Int                      @id @default(autoincrement())
  title                             String
  description                       String
  raisedById                        Int
  assignedMaintenanceStaffProfileId Int?
  status                            ComplaintStatus          @default(OPEN)
  createdAt                         DateTime                 @default(now())
  updatedAt                         DateTime                 @updatedAt
  propertyId                        Int
  requestedVisitDate                DateTime?                @db.Date
  requestedVisitTime                DateTime?                @db.Time(6)
  priority                          MaintenancePriority?
  roomNumber                        String?
  assignedMaintenanceStaffProfile   MaintenanceStaffProfile? @relation(fields: [assignedMaintenanceStaffProfileId], references: [id])
  property                          Property                 @relation(fields: [propertyId], references: [id])
  raisedBy                          User                     @relation("ComplaintRaisedBy", fields: [raisedById], references: [id])
  logs                              ComplaintActivityLog[]
  images                            ComplaintPhoto[]

  @@index([raisedById])
  @@index([assignedMaintenanceStaffProfileId])
  @@index([status])
}

model ComplaintActivityLog {
  id          Int       @id @default(autoincrement())
  title       String
  complaintId Int
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model ComplaintPhoto {
  id          Int       @id @default(autoincrement())
  complaintId Int
  imageUrl    String
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@index([complaintId])
}

model Invoice {
  id                 Int               @id @default(autoincrement())
  tenancyId          Int
  invoiceNumber      String            @unique
  periodStart        DateTime          @db.Date
  periodEnd          DateTime          @db.Date
  balanceAmount      Decimal           @db.Decimal(10, 2)
  baseRentAmount     Decimal           @default(0) @db.Decimal(10, 2)
  cancelReason       String?
  cancelledAt        DateTime?
  createdAt          DateTime          @default(now())
  discountAmount     Decimal           @default(0) @db.Decimal(10, 2)
  dueDate            DateTime          @db.Date
  electricityAmount  Decimal           @default(0) @db.Decimal(10, 2)
  fineAmount         Decimal           @default(0) @db.Decimal(10, 2)
  generatedAt        DateTime          @default(now())
  gracePeriodEnd     DateTime          @db.Date
  invoiceType        InvoiceType
  lateFeeAmount      Decimal           @default(0) @db.Decimal(10, 2)
  maintenanceAmount  Decimal           @default(0) @db.Decimal(10, 2)
  notes              String?
  otherChargesAmount Decimal           @default(0) @db.Decimal(10, 2)
  paidAmount         Decimal           @default(0) @db.Decimal(10, 2)
  paidAt             DateTime?
  propertyId         Int
  status             InvoiceStatus     @default(PENDING)
  totalAmount        Decimal           @db.Decimal(10, 2)
  updatedAt          DateTime          @updatedAt
  waterAmount        Decimal           @default(0) @db.Decimal(10, 2)
  property           Property          @relation(fields: [propertyId], references: [id])
  tenency            Tenancy           @relation(fields: [tenancyId], references: [id])
  invoiceLineItems   InvoiceLineItem[]
  payments           Payment[]

  @@index([tenancyId])
  @@index([propertyId])
  @@index([status])
  @@index([dueDate])
  @@index([invoiceNumber])
  @@index([tenancyId, periodStart, periodEnd])
  @@index([status, dueDate])
  @@index([propertyId, status])
  @@index([propertyId, status, dueDate])
}

model InvoiceLineItem {
  id             Int           @id @default(autoincrement())
  invoiceId      Int
  chargeType     ChargeType
  description    String
  amount         Decimal       @db.Decimal(10, 2)
  quantity       Decimal       @default(1) @db.Decimal(10, 2)
  unitPrice      Decimal?      @db.Decimal(10, 2)
  metadata       Json?
  tenantChargeId Int?
  createdAt      DateTime      @default(now())
  invoice        Invoice       @relation(fields: [invoiceId], references: [id])
  tenantCharge   TenantCharge? @relation(fields: [tenantChargeId], references: [id])

  @@index([invoiceId])
  @@index([chargeType])
  @@index([tenantChargeId])
}

model TenantCharge {
  id              Int               @id @default(autoincrement())
  tenancyId       Int
  propertyId      Int
  chargeType      ChargeType
  title           String
  description     String?
  amount          Decimal           @db.Decimal(10, 2)
  status          ChargeStatus      @default(PENDING)
  invoiceId       Int?
  previousReading Decimal?          @db.Decimal(10, 2)
  currentReading  Decimal?          @db.Decimal(10, 2)
  ratePerUnit     Decimal?          @db.Decimal(10, 4)
  isRecurring     Boolean           @default(false)
  recurringDay    Int?
  addedById       Int
  attachments     String[]
  effectiveDate   DateTime?         @db.Date
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  startDate       DateTime?         @db.Date
  endDate         DateTime?         @db.Date
  lineItems       InvoiceLineItem[]
  property        Property          @relation(fields: [propertyId], references: [id])
  tenancy         Tenancy           @relation(fields: [tenancyId], references: [id])

  @@index([tenancyId])
  @@index([propertyId])
  @@index([status])
  @@index([tenancyId, status])
  @@index([chargeType])
  @@index([effectiveDate])
}

model Payment {
  id               Int           @id @default(autoincrement())
  invoiceId        Int
  tenancyId        Int
  amount           Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  paymentStatus    PaymentStatus @default(INITIATED)
  transactionId    String?       @unique
  gatewayOrderId   String?       @unique
  gatewayPaymentId String?
  gatewaySignature String?
  gatewayResponse  Json?
  paidAt           DateTime?
  failedAt         DateTime?
  refundedAt       DateTime?
  failureReason    String?
  collectedById    Int?
  receiptNumber    String?       @unique
  remarks          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  invoice          Invoice       @relation(fields: [invoiceId], references: [id])
  tenancy          Tenancy       @relation(fields: [tenancyId], references: [id])
  logs             PaymentLog[]

  @@index([invoiceId])
  @@index([tenancyId])
  @@index([paymentStatus])
  @@index([transactionId])
  @@index([gatewayOrderId])
  @@index([createdAt])
  @@index([tenancyId, paymentStatus])
  @@index([invoiceId, paymentStatus])
  @@index([tenancyId, receiptNumber])
}

model PaymentLog {
  id             Int           @id @default(autoincrement())
  paymentId      Int
  previousStatus PaymentStatus
  newStatus      PaymentStatus
  message        String
  metadata       Json?
  createdAt      DateTime      @default(now())
  payment        Payment       @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([createdAt])
}

model ReminderSchedule {
  id             Int                    @id @default(autoincrement())
  tenancyId      Int
  invoiceId      Int?
  reminderType   ReminderType
  scheduledFor   DateTime
  status         ReminderScheduleStatus @default(PENDING)
  attemptCount   Int                    @default(0)
  maxAttempts    Int                    @default(3)
  lastAttemptAt  DateTime?
  nextRetryAt    DateTime?
  channel        NotificationChannel    @default(WHATSAPP)
  recipientPhone String
  recipientName  String
  templateName   String
  templateData   Json
  processedAt    DateTime?
  failedReason   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tenancy        Tenancy                @relation(fields: [tenancyId], references: [id])

  @@index([status, scheduledFor])
  @@index([tenancyId])
  @@index([scheduledFor])
  @@index([status])
  @@index([reminderType, status])
}

model OutBox {
  id          Int          @id @default(autoincrement())
  messageType String
  payload     Json
  status      OutboxStatus @default(PENDING)
  retryCount  Int          @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([messageType])
  @@index([messageType, status])
}

model PropertyMonthlyMetrics {
  id         Int @id @default(autoincrement())
  propertyId Int
  year       Int
  month      Int

  totalIncome Decimal @default(0) @db.Decimal(10, 2)
  rentIncome  Decimal @default(0) @db.Decimal(10, 2)
  otherIncome Decimal @default(0) @db.Decimal(10, 2)

  totalExpenses       Decimal @default(0) @db.Decimal(10, 2)
  salaryExpenses      Decimal @default(0) @db.Decimal(10, 2)
  maintenanceExpenses Decimal @default(0) @db.Decimal(10, 2)
  utilityExpenses     Decimal @default(0) @db.Decimal(10, 2)
  otherExpenses       Decimal @default(0) @db.Decimal(10, 2)

  totalDue        Decimal @default(0) @db.Decimal(10, 2)
  pendingInvoices Int     @default(0)

  activeTenantsCount Int     @default(0)
  occupancyRate      Decimal @default(0) @db.Decimal(5, 2)

  lastCalculatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, year, month])
  @@index([propertyId])
  @@index([year, month])
  @@index([propertyId, year, month])
}

model PropertyLifetimeMetrics {
  id         Int @id @default(autoincrement())
  propertyId Int @unique

  totalIncomeAllTime   Decimal @default(0) @db.Decimal(10, 2)
  totalExpensesAllTime Decimal @default(0) @db.Decimal(10, 2)
  totalDueAllTime      Decimal @default(0) @db.Decimal(10, 2)

  totalTenantsAllTime  Int @default(0)
  totalInvoicesAllTime Int @default(0)
  totalPaymentsAllTime Int @default(0)

  firstActivityDate DateTime?
  lastActivityDate  DateTime?

  lastCalculatedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TenantStatus {
  ACTIVE
  NOTICE_PERIOD
  EXITED
  EVICTED
  PENDING
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  MAINTENANCE_STAFF
}

enum RoomSharingType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintStatus {
  OPEN
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStaffType {
  ADMIN_STAFF
  SERVICE_STAFF
}

enum MaintenanceJobPosition {
  ELECTRICIAN
  PLUMBER
  CLEANER
  CARPENTER
  SECURITY
  MANAGER
  OTHER
  OWNER
  CO_PARTNER
  SUPERVISOR
  ACCOUNTANT
  OPERATIONS_HEAD
}

enum BusinessType {
  INDIVIDUAL
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LIMITED
  LLP
  OTHER
}

enum BusinessDetailsStatus {
  APPROVED
  REJECTED
  PENDING
}

enum BusinessApprovalStatus {
  APPROVED
  REJECTED
  PENDING
}

enum PropertyAccessScope {
  ALL_PROPERTIES
  SELECTIVE
}

enum payeeCategory {
  OWNER
  MANAGER
  STAFF
  EMPLOYEE
  OTHER
}

enum AccountDetailsType {
  BANKACCOUNT
  UPI
  BOTH
}

enum InvoiceType {
  MONTHLY_RENT
  PRORATED_FIRST
  PRORATED_LAST
  ADDITIONAL_CHARGES
  SECURITY_DEPOSIT
  FINAL_SETTLEMENT
}

enum InvoiceStatus {
  DRAFT
  PENDING
  DUE
  OVERDUE
  PARTIALLY_PAID
  PAID
  CANCELLED
  WAIVED
}

enum ChargeType {
  RENT
  ELECTRICITY
  WATER
  MAINTENANCE
  FINE
  LATE_FEE
  SECURITY_DEPOSIT
  ADVANCE
  OTHER
}

enum ChargeStatus {
  PENDING
  ATTACHED
  CANCELLED
}

enum PaymentMethod {
  UPI
  BANK_TRANSFER
  CASH
  CHEQUE
  ONLINE_GATEWAY
  WALLET
  AUTO_DEBIT
}

enum PaymentStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REFUND_INITIATED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum ReminderType {
  PAYMENT_WINDOW_OPEN
  PAYMENT_DUE_SOON
  PAYMENT_DUE_TODAY
  PAYMENT_OVERDUE
  PAYMENT_RECEIVED
  INVOICE_GENERATED
  CHARGE_ADDED
  MOVE_OUT_REMINDER
  WELCOME
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  EXPIRED
}

enum ReminderScheduleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum LateFeeType {
  FIXED
  PERCENTAGE
  PER_DAY_FIXED
  PER_DAY_PERCENTAGE
}

enum SQSMessageType {
  GENERATE_INVOICE
  SEND_REMINDER
  PROCESS_PAYMENT
  APPLY_LATE_FEE
  ATTACH_CHARGES
  SCHEDULE_REMINDERS
  SEND_WHATSAPP
  PAYMENT_CONFIRMATION
  INVOICE_NOTIFICATION
  CHARGE_NOTIFICATION
  CRON_DAILY_BILLING
  CRON_REMINDER_SCAN
}

enum SQSProcessStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum TenancyStatus {
  ACTIVE
  NOTICE_PERIOD
  EXITED
  EVICTED
  PENDING
}
